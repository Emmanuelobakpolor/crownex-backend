# Copy to .env for local development.

# Local dev only — keep True here, must be False (the default) in production.
DEBUG=True

# --- Production (Railway) ---
# Set these as environment variables in the Railway service, not in .env.
#
# SECRET_KEY=<generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
# ALLOWED_HOSTS=your-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# DATABASE_URL=<set automatically by Railway's Postgres plugin>

# --- Media storage (Cloudinary) ---
# Leave unset to keep saving uploads (profile pictures) to local disk, fine
# for dev but lost on every Railway redeploy — required in production.
# Values come from your Cloudinary dashboard.
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (SendGrid) ---
# Leave unset to keep the console backend, which just prints OTP emails to
# the runserver/deploy log.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# SENDGRID_API_KEY=SG.xxxxxxxx
# DEFAULT_FROM_EMAIL=CrownEx <noreply@crownex.app>

# --- Flutterwave (NGN wallet: deposit / withdraw) ---
# Test keys (FLWPUBK_TEST-/FLWSECK_TEST-) from the Flutterwave dashboard work
# out of the box; swap for live keys (FLWPUBK-/FLWSECK-) in production.
# Webhook hash is a secret string you set both here and in the Flutterwave
# dashboard's webhook config — it's compared against the Verif-Hash header
# to authenticate incoming webhook calls.
# FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
# FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
# FLW_WEBHOOK_HASH=change-me-to-a-random-secret

# --- PluginNG (VTU: airtime / data) ---
# PluginNG has no long-lived API key — the backend logs in with these
# credentials itself (POST /login) and caches the resulting token, since a
# hand-pasted token goes stale with no way to recover except a redeploy.
# Use the same email/password you use to sign in at pluginng.com.
# Webhook secret is a random string you choose; set the same value as the
# last path segment of the webhook URL you configure in PluginNG's profile
# section (https://yourdomain.com/api/vtu/webhook/<secret>/), since PluginNG
# doesn't sign its webhook payloads.
# PLUGINNG_BASE_URL=https://pluginng.com/api
# PLUGINNG_EMAIL=you@example.com
# PLUGINNG_PASSWORD=your-pluginng-account-password
# PLUGINNG_WEBHOOK_SECRET=change-me-to-a-random-secret

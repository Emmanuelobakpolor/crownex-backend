# Copy to .env for local development.

# Local dev only — keep True here, must be False (the default) in production.
DEBUG=True

# --- Production (Railway) ---
# Set these as environment variables in the Railway service, not in .env.
#
# SECRET_KEY=<generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
# ALLOWED_HOSTS=your-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# DATABASE_URL=<set automatically by Railway's Postgres plugin>

# --- Media storage (Cloudinary) ---
# Leave unset to keep saving uploads (profile pictures) to local disk, fine
# for dev but lost on every Railway redeploy — required in production.
# Values come from your Cloudinary dashboard.
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=123456789012345
# CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Email (SendGrid) ---
# Leave unset to keep the console backend, which just prints OTP emails to
# the runserver/deploy log.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# SENDGRID_API_KEY=SG.xxxxxxxx
# DEFAULT_FROM_EMAIL=CrownEx <noreply@crownex.app>

# --- Flutterwave v4 (NGN wallet: deposit / withdraw) ---
# Client ID/Secret/Encryption key come from the dashboard's API Keys page
# (Test API keys tab for these, Live API keys for production — v4 only
# issues OAuth2 client-credentials, not the old static FLWPUBK-/FLWSECK-
# keys). FLW_BASE_URL defaults to the sandbox F4B endpoint; point it at
# .../f4b/production once you're using live credentials.
# Webhook hash is a secret string you invent, set both here and in the
# Flutterwave dashboard's webhook config — it's used to verify the
# flutterwave-signature header (HMAC-SHA256) on incoming webhook calls.
# FLW_BASE_URL=https://api.flutterwave.cloud/f4b/sandbox
#
# Individual resource paths, overridable independently if Flutterwave
# renames one without changing its request/response shape (defaults shown
# — only set the ones you need to change):
# FLW_ORDERS_ENDPOINT=/orchestration/direct-orders
# FLW_ORDER_GET_ENDPOINT=/orders
# FLW_TRANSFERS_ENDPOINT=/transfers
# FLW_TRANSFER_RECIPIENTS_ENDPOINT=/transfers/recipients
# FLW_BANKS_ENDPOINT=/banks
# FLW_BANK_RESOLVE_ENDPOINT=/banks/account-resolve
#
# FLW_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# FLW_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FLW_WEBHOOK_HASH=change-me-to-a-random-secret
